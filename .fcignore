# 阿里云函数计算部署忽略文件

# 依赖目录（部署时会重新安装）
node_modules/

# 开发文件
.next/
.git/
.gitignore

# 日志文件
*.log
logs/

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 测试文件
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage/

# 文档
*.md
!README.md

# 环境配置（安全考虑，在阿里云控制台配置）
.env
.env.local
.env.*.local

# 临时文件
tmp/
temp/
*.tmp

# 脚手架配置
.cozeproj/
