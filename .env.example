# ============================================
# VES 互动短剧平台 - 环境变量配置模板
# ============================================
# 使用方法：
# 1. 复制此文件为 .env.local
# 2. 填入你的 Supabase 配置
# 3. Vercel 部署时也需要配置这些变量
# ============================================

# Supabase 配置（服务端使用）
# 从 Supabase 控制台 → Settings → API 获取
COZE_SUPABASE_URL=https://your-project-id.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase 配置（客户端使用 - 需要 NEXT_PUBLIC_ 前缀）
# 这两个值与上面相同，但变量名不同
NEXT_PUBLIC_COZE_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_COZE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# 可选配置
# ============================================

# 对象存储配置（如果使用自定义 S3）
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET=your-bucket-name
# S3_REGION=auto
# S3_ENDPOINT=https://your-endpoint.com

# 站点配置
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
# NEXT_PUBLIC_SITE_NAME=VES 互动短剧
